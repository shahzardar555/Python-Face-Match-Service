FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=True

# Confidence threshold for face match
# Above this = match, below = no match
MATCH_THRESHOLD=

# Maximum image size in MB
MAX_IMAGE_SIZE_MB=10

# Allowed image formats
ALLOWED_FORMATS=jpg,jpeg,png,webp

# Cloudinary credentials (for downloading images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
